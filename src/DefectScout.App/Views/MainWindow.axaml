<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DefectScout.App.ViewModels"
        xmlns:views="using:DefectScout.App.Views.Pages"
        x:Class="DefectScout.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Defect Scout"
        Width="1100" Height="750"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.DataTemplates>
        <!-- Page DataTemplates — ContentControl picks the right view automatically -->
        <DataTemplate DataType="{x:Type vm:WelcomeViewModel}">
            <views:WelcomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SetupViewModel}">
            <views:SetupView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TicketInputViewModel}">
            <views:TicketInputView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StepReviewViewModel}">
            <views:StepReviewView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RunningViewModel}">
            <views:RunningView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportViewModel}">
            <views:ReportView />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid RowDefinitions="Auto,*">

        <!-- ── Top navigation breadcrumb bar ── -->
        <Border Grid.Row="0"
                Background="{DynamicResource SystemAccentColor}"
                Padding="16,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="🔍 Defect Scout"
                           FontSize="16" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center" />
                <TextBlock Text="·"
                           Foreground="White" Opacity="0.5"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding CurrentPageTitle}"
                           Foreground="White"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ── Main page content ── -->
        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentPage}" />
    </Grid>

</Window>
